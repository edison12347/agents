chuday.eu {
	# Force HTTP/1.1 for WebSocket support
	protocols h1
	
	# Handle WebSocket upgrades FIRST (before redirect)
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	
	# Proxy WebSocket connections directly to gateway
	reverse_proxy @websocket host.docker.internal:18789
	
	# Redirect non-WebSocket root requests to control UI
	@not_websocket {
		path /
		not header Connection *Upgrade*
	}
	
	redir @not_websocket /clawagent/ permanent
	
	# Proxy all /clawagent paths
	reverse_proxy /clawagent* host.docker.internal:18789
}

# Odoo subdomain
odoo.chuday.eu {
	log {
		output file /var/log/caddy/odoo.log
		level INFO
	}
	
	# Proxy to Odoo on host
	reverse_proxy host.docker.internal:8069 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		
		# Increase timeouts for Odoo long-polling
		transport http {
			read_timeout 3600s
			write_timeout 3600s
		}
	}
	
	# Enable compression
	encode gzip
}
