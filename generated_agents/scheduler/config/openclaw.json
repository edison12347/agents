{
  "gateway": {
    "mode": "local",
    "bind": "loopback"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex",
        "fallbacks": [
          "anthropic/claude-sonnet-4-5"
        ]
      },
      "workspace": "/home/builder/generated_agents/scheduler/workspace"
    },
    "list": [
      {
        "id": "scheduler",
        "default": true,
        "subagents": {
          "allowAgents": [
            "builder"
          ]
        }
      },
      {
        "id": "builder",
        "workspace": "/home/builder/workspace",
        "model": "openai-codex/gpt-5.3-codex"
      }
    ]
  },
  "skills": {
    "entries": {
      "builder": {
        "enabled": true
      }
    },
    "load": {
      "extraDirs": [
        "/home/builder/generated_agents/scheduler/skills"
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN_AIVAR}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "${TELEGRAM_OWNER_ID}"
      ],
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1
  },
  "tools": {
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    }
  }
}