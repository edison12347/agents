{
  "gateway": {
    "mode": "local",
    "bind": "loopback"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-5"
      },
      "workspace": "/home/builder/generated_agents/lina-pm-agent/workspace"
    },
    "list": [
      {
        "id": "lina-pm-agent",
        "default": true
      }
    ]
  },
  "skills": {
    "entries": {
      "builder": {
        "enabled": true
      }
    },
    "load": {
      "extraDirs": [
        "/home/builder/generated_agents/lina-pm-agent/skills"
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN_LINA}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "${TELEGRAM_OWNER_ID}"
      ],
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1
  }
}