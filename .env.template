# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional (defaults pre-configured) ──────────────────────────────────────
# YouTube channel handle or full URL
YOUTUBE_CHANNEL=@alphamediachannel

# How many hours back to look for new videos (default: 24)
LOOKBACK_HOURS=24

# Daily run time in cron format UTC (default: 08:00 UTC)
CRON_SCHEDULE=0 8 * * *

# Custom summary prompt — edit this to change how Claude summarises the digest
SUMMARY_PROMPT=You are a news editor. Summarise the following YouTube videos from Alpha Media Channel into a concise daily digest. Highlight the key news stories, important events, and notable topics covered. Use clear bullet points, starting each with an emoji that fits the topic. End with a one-line overall takeaway.
